{
  "component": {
    "button": {
      "default-bg": "var(--global-color-gray-00)",
      "default-border": "var(--global-color-gray-300)",
      "default-text": "var(--global-color-gray-900)",

      "primary-bg": "var(--global-color-primary-500)",
      "secondary-bg": "var(--global-color-secondary-500)",
      "outline-bg": "transparent",
      "link-bg": "transparent",

      "primary-border": "var(--global-color-primary-500)",
      "secondary-border": "var(--global-color-secondary-500)",
      "outline-border": "var(--global-color-primary-500)",
      "link-border": "transparent",

      "primary-text": "var(--global-color-gray-00)",
      "secondary-text": "var(--global-color-gray-00)",
      "outline-text": "var(--global-color-primary-500)",
      "link-text": "var(--global-color-primary-500)",

      "radius": "0.5rem",
      "padding-inline-sm": "0.75rem",
      "padding-inline-md": "1rem",
      "padding-inline-lg": "1.25rem",
      "height-sm": "2rem",
      "height-md": "2.5rem",
      "height-lg": "3rem",
      "font-size-sm": "var(--global-font-size-2)",
      "font-size-md": "var(--global-font-size-3)",
      "font-size-lg": "var(--global-font-size-4)",

      "filter-bg": "var(--global-color-gray-00)",
      "filter-border": "var(--color-border)",
      "filter-text": "var(--color-text)",
      "filter-hover-bg": "var(--color-background)",
      "filter-radius": "0.75rem",
      "filter-gap": "0.5rem",
      "filter-font-weight": "500"
    },

    "input": {
      "bg": "var(--color-surface)",
      "text": "var(--color-text)",
      "placeholder": "var(--color-text-muted)",
      "radius": "0.5rem",

      "default-border": "var(--color-border)",
      "default-focus-border": "var(--global-color-primary-500)",
      "error-border": "var(--global-color-danger-500)",
      "error-focus-border": "var(--global-color-danger-500)",
      "success-border": "var(--global-color-success-500)",
      "success-focus-border": "var(--global-color-success-500)",

      "focus-ring": "var(--color-focus-ring)",
      "disabled-bg": "var(--color-background)",
      "disabled-opacity": "0.7",

      "height-sm": "2rem",
      "height-md": "2.5rem",
      "height-lg": "3rem",
      "padding-inline-sm": "0.5rem",
      "padding-inline-md": "0.75rem",
      "padding-inline-lg": "1rem",
      "font-size-sm": "var(--global-font-size-2)",
      "font-size-md": "var(--global-font-size-3)",
      "font-size-lg": "var(--global-font-size-4)"
    },

    "checkbox": {
      "size": "1rem",
      "radius": "0.25rem",
      "icon-size": "0.75rem",
      "border-width": "1px",

      "active-bg": "var(--global-color-primary-500)",
      "active-border": "var(--global-color-primary-500)",
      "active-text": "var(--color-surface)",

      "inactive-bg": "var(--color-background)",
      "inactive-border": "var(--color-text-muted)",
      "inactive-text": "transparent",

      "hover-border": "var(--global-color-primary-400)",
      "focus-ring": "var(--color-focus-ring)"
    },

    "drawer": {
      "overlay-bg": "rgba(0, 0, 0, 0.4)",
      "panel-bg": "var(--color-surface)",
      "panel-max-width": "420px",
      "panel-shadow": "0 25px 50px -12px rgba(0, 0, 0, 0.25)",

      "header-padding-x": "1.25rem",
      "header-padding-y": "1rem",
      "body-padding-x": "1rem",
      "body-padding-y": "0.75rem",
      "footer-padding-x": "1.25rem",
      "footer-padding-y": "1rem",
      "footer-gap": "0.75rem",

      "border-color": "var(--color-border)",
      "title-size": "0.9375rem",
      "title-weight": "600",
      "title-color": "var(--color-text)",
      "description-size": "0.8125rem",
      "description-color": "var(--color-text-muted)",

      "animation-duration": "300ms",
      "animation-easing": "cubic-bezier(0.4, 0, 0.2, 1)"
    },

    "badge": {
      "primary-bg": "var(--color-primary)",
      "primary-text": "var(--color-surface)",
      "secondary-bg": "var(--color-secondary)",
      "secondary-text": "var(--color-surface)",
      "success-bg": "var(--color-success)",
      "success-text": "var(--color-surface)",
      "error-bg": "var(--color-error)",
      "error-text": "var(--color-surface)",

      "radius": "9999px",
      "font-weight": "500",

      "padding-x-sm": "0.5rem",
      "padding-y-sm": "0.125rem",
      "font-size-sm": "var(--global-font-size-1)",

      "padding-x-md": "0.625rem",
      "padding-y-md": "0.25rem",
      "font-size-md": "var(--global-font-size-2)",

      "padding-x-lg": "0.75rem",
      "padding-y-lg": "0.375rem",
      "font-size-lg": "var(--global-font-size-3)"
    },

    "card": {
      "default-bg": "var(--color-surface)",
      "default-border": "var(--color-border)",
      "default-border-width": "1px",
      "default-shadow": "none",

      "outlined-bg": "var(--color-surface)",
      "outlined-border": "var(--color-secondary)",
      "outlined-border-width": "2px",
      "outlined-shadow": "none",

      "elevated-bg": "var(--color-surface)",
      "elevated-border": "transparent",
      "elevated-border-width": "1px",
      "elevated-shadow": "var(--global-effect-dropdown-shadow)",

      "radius": "0.5rem",
      "padding-sm": "0.75rem",
      "padding-md": "1rem",
      "padding-lg": "1.5rem",

      "title-font-size": "var(--global-font-size-5)",
      "title-font-weight": "600",
      "title-color": "var(--color-text)",
      "title-margin-bottom": "0.5rem",

      "description-font-size": "var(--global-font-size-2)",
      "description-color": "var(--color-text-muted)",

      "body-margin-top": "0.75rem",
      "body-font-size": "var(--global-font-size-2)",
      "body-color": "var(--color-text)"
    },

    "toggle": {
      "track-bg": "var(--color-border)",
      "track-radius": "9999px",
      "track-padding": "0.125rem",

      "primary-active-bg": "var(--color-primary)",
      "secondary-active-bg": "var(--color-secondary)",
      "outline-active-bg": "var(--color-text-muted)",
      "outline-border": "var(--color-border)",

      "thumb-bg": "var(--color-surface)",
      "thumb-radius": "9999px",
      "thumb-shadow": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",

      "track-height-sm": "1.25rem",
      "track-width-sm": "2.25rem",
      "thumb-size-sm": "1rem",
      "thumb-translate-sm": "1rem",

      "track-height-md": "1.5rem",
      "track-width-md": "2.75rem",
      "thumb-size-md": "1.25rem",
      "thumb-translate-md": "1.25rem",

      "track-height-lg": "1.75rem",
      "track-width-lg": "3.5rem",
      "thumb-size-lg": "1.5rem",
      "thumb-translate-lg": "1.75rem",

      "focus-ring": "var(--color-focus-ring)",
      "disabled-opacity": "0.5"
    },

    "tabs": {
      "container-bg": "var(--color-background)",
      "container-border": "var(--color-border)",
      "container-radius": "0.75rem",
      "container-padding": "0.25rem",

      "tab-height": "2.25rem",
      "tab-radius": "0.5rem",
      "tab-padding-x": "0.75rem",
      "tab-font-size": "var(--global-font-size-2)",
      "tab-font-weight": "500",

      "active-bg": "var(--color-surface)",
      "active-text": "var(--color-text)",
      "active-shadow": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",

      "inactive-text": "var(--color-text-muted)",
      "hover-bg": "var(--color-surface)",
      "hover-text": "var(--color-text)",

      "disabled-opacity": "0.5",
      "focus-ring": "var(--global-color-primary-500)"
    }
  }
}
